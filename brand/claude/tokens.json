{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "brand": {
    "name": "dlerhetal.tech",
    "tagline": "Tools and field notes for small trade shops.",
    "voice": "Working shop. Hands-on, snarky, direct. Not corporate, not pastel, not magazine.",
    "tagline_alt": "Dale's Nerd Things"
  },
  "color": {
    "navy":       { "value": "#1A3C6E", "role": "primary", "notes": "Core brand color. Navigation, headings, primary marks." },
    "navy_dark":  { "value": "#0F2748", "role": "primary-hover", "notes": "Hover/active state for navy." },
    "lava":       { "value": "#CF2A27", "role": "accent", "notes": "Links, live status, emphasis. Never more than ~10% of surface." },
    "lava_dark":  { "value": "#A11F1C", "role": "accent-hover", "notes": "Hover/active state for lava." },
    "stone":      { "value": "#E6E9EE", "role": "base", "notes": "Page background. Pale cool stone." },
    "surface":    { "value": "#F2F4F7", "role": "surface", "notes": "Card / panel background, one step above stone." },
    "olive":      { "value": "#556B2F", "role": "secondary-accent", "notes": "Section labels, coming-soon status, rules." },
    "text":       { "value": "#14213D", "role": "text", "notes": "Body copy. Darker than navy, for legibility." },
    "muted":      { "value": "#5B6777", "role": "text-muted", "notes": "Secondary copy, captions, metadata." },
    "border":     { "value": "rgba(26, 60, 110, 0.22)", "role": "border", "notes": "Hairline rules and card borders." }
  },
  "typography": {
    "family_sans": "'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif",
    "family_mono": "ui-monospace, 'Cascadia Mono', 'Consolas', monospace",
    "weights": { "regular": 400, "semibold": 600, "bold": 700 },
    "scale": {
      "xs":   "11px",
      "sm":   "13px",
      "base": "16px",
      "md":   "17px",
      "lg":   "18px",
      "xl":   "24px",
      "2xl":  "32px",
      "3xl":  "48px"
    },
    "leading": { "tight": 1.25, "normal": 1.55, "loose": 1.7 },
    "tracking_label": "0.12em"
  },
  "space": {
    "0": "0",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px"
  },
  "radius": { "sm": "3px", "md": "6px", "lg": "12px", "pill": "999px" },
  "layout": { "max_width": "960px", "gutter": "24px" },
  "logo": {
    "clear_space": "Minimum clear space on all sides equals the diameter of the inner bowl (approximately 25% of the mark's total width).",
    "min_size_px": { "full_mark": 32, "favicon_variant": 16 },
    "files": {
      "primary":      "brand/logo/logo-primary.svg",
      "reversed":     "brand/logo/logo-reversed.svg",
      "lava":         "brand/logo/logo-lava.svg",
      "mono_navy":    "brand/logo/logo-mono-navy.svg",
      "mono_stone":   "brand/logo/logo-mono-stone.svg",
      "wordmark":     "brand/logo/logo-wordmark.svg",
      "favicon_svg":  "brand/favicon/favicon-source.svg"
    }
  }
}
